# API Server Configuration
RAG_HOST=0.0.0.0
RAG_PORT=8000
DEBUG_RAG_API=False

# Google Generative AI Configuration
# Get an API key from Google AI Studio: https://aistudio.google.com/
RAG_GOOGLE_API_KEY=your_google_api_key_here
EMBEDDINGS_MODEL=gemini-embedding-001

# PostgreSQL Vector Database Configuration
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
DB_HOST=localhost
DB_PORT=5433
POSTGRES_SCHEMA=public
COLLECTION_NAME=testcollection

# JWT Token Authentication Secret (Optional: if not set, JWT validation is skipped)
# JWT_SECRET=your_jwt_secret_here

# UI Configuration (Set to True to serve the frontend user interface at root "/")
RAG_SERVE_UI=False
